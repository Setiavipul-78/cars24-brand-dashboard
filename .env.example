# ── YouTube ───────────────────────────────────────────────────────────────────
# Generated by: python3 setup_youtube_auth.py
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
YT_REFRESH_TOKEN=1//xxxx

# YouTube channel IDs (get from: youtube.com → channel page → /channel/UCxxxx in URL)
YT_CHANNEL_ID_CARS24_INDIA=UCxxxxxxxxxxxxxxxxxxxxxx
YT_CHANNEL_ID_TEAMBHP=UCxxxxxxxxxxxxxxxxxxxxxx
YT_CHANNEL_ID_INSIDER=UCxxxxxxxxxxxxxxxxxxxxxx
YT_CHANNEL_ID_AU=UCxxxxxxxxxxxxxxxxxxxxxx
YT_CHANNEL_ID_UAE=UCxxxxxxxxxxxxxxxxxxxxxx

# ── Instagram ─────────────────────────────────────────────────────────────────
# Get User ID: Meta for Developers → Graph API Explorer → GET /me?fields=id → copy id
# Get token: Graph API Explorer → Generate User Access Token → select instagram_basic,
#            instagram_manage_insights → extend to long-lived (60 days)
# Full guide: https://developers.facebook.com/docs/instagram-api/getting-started

IG_USER_ID_CARS24_INDIA=17841xxxxxxxxx
IG_USER_ID_TEAMBHP=17841xxxxxxxxx
IG_USER_ID_AU=17841xxxxxxxxx
IG_USER_ID_UAE=17841xxxxxxxxx

# Shared token (if one Meta App manages all pages) or per-account tokens:
IG_ACCESS_TOKEN=EAAxxxxxxxxxx

# Per-account tokens (optional; override shared token if set):
# IG_ACCESS_TOKEN_CARS24_INDIA=EAAxxxxxxxxxx
# IG_ACCESS_TOKEN_TEAMBHP=EAAxxxxxxxxxx
# IG_ACCESS_TOKEN_AU=EAAxxxxxxxxxx
# IG_ACCESS_TOKEN_UAE=EAAxxxxxxxxxx
